{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cookbook.dev/schemas/self-improvement/v1/gate-observation.schema.json",
  "title": "GateObservation",
  "type": "object",
  "required": [
    "observation_id", "task_id", "occurred_at", "gate_id", "owner",
    "policy_revision", "decision", "effective_action", "transition_changed",
    "risk", "override", "source_event_id"
  ],
  "additionalProperties": false,
  "properties": {
    "observation_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "gate_id": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "policy_revision": { "type": "string", "minLength": 1 },
    "decision": { "enum": ["pass", "warn", "hold", "block", "unknown"] },
    "effective_action": { "enum": ["continue", "hold", "block", "unknown"] },
    "transition_changed": { "oneOf": [{ "type": "boolean" }, { "const": "unknown" }] },
    "risk": { "type": "string", "minLength": 1 },
    "override": { "enum": ["none", "applied", "unknown"] },
    "source_event_id": { "type": "string", "minLength": 1 }
  }
}
